<!DOCTYPE html>
<html>
<head>
    <title>Cricket Game</title>
</head>
<body style="text-align:center; font-family:Arial;">
    <h1>🏏 Simple Cricket Game</h1>

    <button onclick="play()">Play Shot</button>

    <h2 id="result"></h2>
    <h3 id="score">Score: 0</h3>

    <script>
        let score = 0;

        function play() {
            let runs = Math.floor(Math.random() * 7); // 0–6 runs

            if (runs === 0) {
                document.getElementById("result").innerText = "OUT!";
                score = 0;
            } else {
                document.getElementById("result").innerText = "You scored " + runs + " runs!";
                score += runs;
            }

            document.getElementById("score").innerText = "Score: " + score;
        }
    </script>
</body>
</html>